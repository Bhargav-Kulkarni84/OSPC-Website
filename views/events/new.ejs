<% layout('layouts/boilerplate') %>

<div class="container mt-4">
  <h2 class="mb-4">Add a New Event</h2>
  
  <form action="/admin/addevent" method="POST" novalidate class="validated-form">
    <div class="row mb-3">
      <div class="col-md-6">
        <label class="form-label" for="Title">Title:</label>
        <input class="form-control" type="text" id="Title" name="Title" required>
      </div>
    </div>

    <div class="row mb-3">
      <div class="col-md-6">
        <label class="form-label" for="Image">Image URL:</label>
        <input class="form-control" type="text" id="Image" name="Image" required>
      </div>
    </div>

    <div class="row mb-3">
      <div class="col-md-6">
        <label class="form-label" for="Date">Date:</label>
        <input class="form-control" type="text" id="Date" name="Date" required>
      </div>
    </div>

    <div class="row mb-3">
      <div class="col-md-6">
        <label class="form-label" for="Year">Timing:</label>
        <input class="form-control" type="text" id="Timing" name="Timing" required>
      </div>
    </div>

    <div class="row mb-3">
      <div class="col-md-6">
        <label class="form-label" for="Year">Seats:</label>
        <input class="form-control" type="number" id="Seats" name="Seats" required>
      </div>
    </div>


    <button class="btn btn-primary" type="submit">Submit</button>
  </form>
</div>
