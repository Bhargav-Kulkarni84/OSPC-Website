<% layout('./layouts/boilerplate') %>

<style>
    /* Scoped styling for the event layout to avoid interference with other sections */
    .event-section {
        padding: 20px;
    }

    .event {
        border: 1px solid #ccc;
        margin: 20px;
        padding: 20px;
        width: 300px;
        float: left;
        background-color: #f9f9f9; /* Add background to differentiate it from the footer */
    }

    .event h3 {
        margin-bottom: 10px;
    }

    .event-placeholder {
        width: 100%;
        height: 200px; /* Adjust the height based on your preference */
        background-color: #d3d3d3; /* Light gray background as a placeholder */
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 16px;
        color: #555;
        margin-bottom: 10px;
    }

    .container {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
    }

    /* Add a clearfix to make sure containers behave correctly */
    .container::after {
        content: "";
        display: table;
        clear: both;
    }

    /* Ensure no interference with global body styles from other components */
    body {
        margin: 0;
    }

    .event-section h1 {
        margin-bottom: 20px;
    }
</style>

<body>

    <h1>Upcoming Events</h1>
    


    <div class="event-section">
        <h1>Our Past Events</h1>
        <div class="container">
            <!-- Event 1 -->
            <div class="event">
                <h3>Event Name 1</h3>
                <!-- <img src="event1-image.jpg" alt="Event 1 Image"> -->
                <div class="event-placeholder">Image Placeholder</div>
                <p>Outcome: This event was very successful...</p>
            </div>
            
            <!-- Event 2 -->
            <div class="event">
                <h3>Event Name 2</h3>
                <!-- <img src="event2-image.jpg" alt="Event 2 Image"> -->
                <div class="event-placeholder">Image Placeholder</div>
                <p>Outcome: This event had great participation...</p>
            </div>
            <!-- More events can be added here -->
        </div>
    </div>
</body>
