<% layout('./layouts/boilerplate') %>

<style>
    /* Scoped styling for the event layout to avoid interference with other sections */
    .event-section {
        padding: 20px;
    }

    .event {
        border: 1px solid #ccc;
        margin: 20px;
        padding: 20px;
        width: 300px;
        float: left;
        background-color: #f9f9f9; /* Add background to differentiate it from the footer */
    }

    .event h3 {
        margin-bottom: 10px;
    }

    .event-placeholder {
        width: 100%;
        height: 200px; /* Adjust the height based on your preference */
        background-color: #d3d3d3; /* Light gray background as a placeholder */
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 16px;
        color: #555;
        margin-bottom: 10px;
    }

    .container {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
    }

    /* Add a clearfix to make sure containers behave correctly */
    .container::after {
        content: "";
        display: table;
        clear: both;
    }

    /* Ensure no interference with global body styles from other components */
    body {
        margin: 0;
    }

    .event-section h1 {
        margin-bottom: 20px;
    }
</style>

<body>

    <h1>Upcoming Events</h1>

    <% for(let event of events) { %>
        <% if(new Date(event.Date) > Date.now()) { %> <!-- Correct Date comparison -->
            <div class="event">
                <!-- <div class="event-placeholder">
                    <img src="<%= event.Image %>" alt="Event Image">
                </div> -->
                <h3><%= event.Title %></h3>
                <p>Date: <%= event.Date.toDateString() %></p>
                <p>Seats Available: <%= event.Seats %></p>
                <p>Timing: <%= event.Timing %></p>
                <%if(!event.Registred){ %>
                <a href="/user/register/<%=event.id %>">Register</a>
                <% } %>
                <%if(event.Registred){ %>
                    <p>Thank You For Registering</p>
                <% } %>
            </div>
        <% } %>
    <% } %>
    
    <h1>Our Past Events</h1>
    
    <% for(let event of events) { %>
        <% if(new Date(event.Date) < Date.now()) { %> <!-- Correct Date comparison -->
            <div class="event">
                <!-- <div class="event-placeholder">
                    <img src="<%= event.Image %>" alt="Event Image">
                </div> -->
                <h3><%= event.Title %></h3>
                <p>Date: <%= event.Date.toDateString() %></p>
                <!-- <p>Seats Available: <%= event.Seats %></p> -->
                <p>Timing: <%= event.Timing %></p>
                <p>View Details</p>
            </div>
        <% } %>
    <% } %>
    
<h1>If you are a admin </h1>
<h2>admin route</h2>
<h3>You will be able to create new event and modify them</h3>

<a href="/admin/events">Events Page</a>

</body>
