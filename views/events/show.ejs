<% layout('./layouts/boilerplate') %>

<h1>
    Upcoming Events
    
    <h3><%=event.Title%></h3>
    <h4><%=event.Image %></h4>
    <h4><%=event.Timing%></h4>
    <h4><%=event.Date%></h4>
    <h4><%=event.Seats%></h4>
    
</h1>

<a href="/admin/editevent/<%=event.id %>"><h2>Edit Event</h2></a>

<form action="/admin/deleteevent/<%=event.id %>?_method=DELETE" method="POST">    
    <button class="btn btn-primary" type="submit">Delete Event</button>
</form>


<h1>
    Previous Events
</h1>
